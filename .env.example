# OKO Server Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to git!

# ── Server ──────────────────────────────────
PORT=3000

# ── Email (SMTP) ─────────────────────────────
# Use your VPS mail provider / Yandex / any SMTP
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=hello@oko.co
SMTP_PASS=your-password-here

# ── Business ─────────────────────────────────
# This email receives all new order notifications
OWNER_EMAIL=hello@oko.co
SITE_URL=https://oko.co
